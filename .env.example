# Local Development API Configuration
# Copy this file to .env and update with your local IP address
# This file is gitignored so each team member can have their own configuration
# 
# For iOS Simulator/Android Emulator: use localhost
# For physical devices: replace localhost with your computer's IP address
# Example: http://192.168.1.6:5001/i-leaf-u/us-central1

LOCAL_BASE_URL=http://localhost:5001/i-leaf-u/us-central1

# Optional: set to false to use legacy Leaf Trail UI (dev and production release builds).
# Hub spec is ON by default; no .env entry needed.
# ENABLE_TRAIL1_FOR_RECEIVING=false

# Optional: override base for shared listing links (default https://ileafu.com)
# PLANT_SHARE_BASE_URL=https://ileafu.com
