{
  "name": "ileafu",
  "version": "0.0.24",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "lint:ci-gate": "eslint jest.config.js jest.setup.js __tests__ __mocks__ metro.config.js",
    "start": "react-native start",
    "start:lite": "REACT_NATIVE_NO_FUSEBOX_PREPARE=1 react-native start",
    "test": "jest",
    "prebuild:android": "node scripts/validate-api-config.js",
    "build:android": "NODE_ENV=production cd android && ./gradlew assembleRelease",
    "prebuild:android-bundle": "node scripts/validate-api-config.js",
    "build:android-bundle": "NODE_ENV=production cd android && ./gradlew bundleRelease",
    "build:ios-bundle": "NODE_ENV=production npx react-native bundle --platform ios --dev false --entry-file index.js --bundle-output ios/main.jsbundle --assets-dest ios",
    "build:ios": "npm run build:ios-bundle && cd ios && xcodebuild -workspace iLeafU.xcworkspace -scheme iLeafU -configuration Release -archivePath build/iLeafU.xcarchive archive",
    "build:ios-simulator": "npm run build:ios-bundle && cd ios && xcodebuild -workspace iLeafU.xcworkspace -scheme iLeafU -configuration Release -sdk iphonesimulator -derivedDataPath build",
    "clean": "cd android && ./gradlew clean && cd .. && rm -rf node_modules && npm install",
    "clean:android": "cd android && ./gradlew clean && rm -rf app/build build app/.cxx",
    "clean:ios": "rm -rf ios/build && rm -f ios/main.jsbundle",
    "clean:all": "npm run clean:android && npm run clean:ios && rm -rf $TMPDIR/react-* $TMPDIR/metro-* $TMPDIR/haste-* && watchman watch-del-all 2>/dev/null || true",
    "reset-cache": "npx react-native start --reset-cache",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^1.24.0",
    "@react-native-clipboard/clipboard": "^1.16.3",
    "@react-native-community/checkbox": "^0.5.20",
    "@react-native-community/datetimepicker": "^8.2.0",
    "@react-native-community/netinfo": "^11.4.1",
    "@react-native-community/slider": "^5.1.2",
    "@react-native-firebase/app": "^24.0.0",
    "@react-native-firebase/auth": "^24.0.0",
    "@react-native-firebase/storage": "^24.0.0",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "dayjs": "^1.11.13",
    "firebase": "^10.12.4",
    "js-base64": "^3.7.8",
    "jwt-decode": "^4.0.0",
    "moment": "^2.30.1",
    "react": "19.2.3",
    "react-native": "0.84.0",
    "react-native-agora": "^4.5.3",
    "react-native-chart-kit": "^6.12.0",
    "react-native-compressor": "^1.16.0",
    "react-native-create-thumbnail": "^2.2.0",
    "react-native-document-picker": "^9.3.1",
    "react-native-file-viewer": "^2.1.5",
    "react-native-fs": "^2.20.0",
    "react-native-gesture-handler": "^2.31.1",
    "react-native-image-pan-zoom": "^2.1.12",
    "react-native-image-picker": "^8.2.0",
    "react-native-keep-awake": "^4.0.0",
    "react-native-modal-datetime-picker": "^18.0.0",
    "react-native-navigation-bar-color": "^2.0.2",
    "react-native-pager-view": "^6.9.1",
    "react-native-reanimated": "4.3.0",
    "react-native-reanimated-carousel": "^4.0.2",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-screens": "^4.24.0",
    "react-native-share": "^12.2.1",
    "react-native-svg": "^15.15.4",
    "react-native-svg-transformer": "^1.5.0",
    "react-native-tab-view": "^4.1.3",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-video": "^6.19.0",
    "react-native-vision-camera": "^4.7.2",
    "react-native-worklets": "0.8.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.84.0",
    "@react-native/eslint-config": "0.84.0",
    "@react-native/metro-config": "0.84.0",
    "@react-native/typescript-config": "0.84.0",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "babel-jest": "^29.6.3",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "patch-package": "^8.0.0",
    "prettier": "2.8.8",
    "react-native-dotenv": "^3.4.11",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=22.11.0"
  },
  "codegenConfig": {
    "name": "iLeafUSpec",
    "type": "all",
    "jsSrcsDir": "src",
    "ios": {
      "modules": {}
    }
  }
}
