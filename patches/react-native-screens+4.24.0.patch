diff --git a/node_modules/react-native-screens/ios/RNSScreenContainer.mm b/node_modules/react-native-screens/ios/RNSScreenContainer.mm
index ae0fd54..231960a 100644
--- a/node_modules/react-native-screens/ios/RNSScreenContainer.mm
+++ b/node_modules/react-native-screens/ios/RNSScreenContainer.mm
@@ -5,6 +5,7 @@
 #ifdef RCT_NEW_ARCH_ENABLED
 #import <React/RCTConversions.h>
 #import <React/RCTFabricComponentsPlugins.h>
+#import <React/RCTLegacyViewManagerInteropComponentView.h>
 #import <react/renderer/components/rnscreens/ComponentDescriptors.h>
 #import <react/renderer/components/rnscreens/Props.h>
 
@@ -99,15 +100,60 @@ namespace react = facebook::react;
 RNS_IGNORE_SUPER_CALL_BEGIN
 - (void)insertReactSubview:(RNSScreenView *)subview atIndex:(NSInteger)atIndex
 {
+#if RCT_NEW_ARCH_ENABLED
+  // When RNSScreenContainer is mounted via RCTLegacyViewManagerInteropComponentView, children are
+  // delivered through this Paper hook. The child may still be the interop wrapper; unwrap to the
+  // inner paper view (RNSScreenView). Using the wrapper here caused doesNotRecognizeSelector
+  // (e.g. setReactSuperview:) and crashes after login when deeper navigation trees mount.
+  UIView *child = subview;
+  if ([child isKindOfClass:[RCTLegacyViewManagerInteropComponentView class]]) {
+    RCTLegacyViewManagerInteropComponentView *interop = (RCTLegacyViewManagerInteropComponentView *)child;
+    // `contentView` is assigned late in finalizeUpdates; `paperView` forces the adapter/paper view.
+    UIView *inner = interop.contentView ?: interop.paperView;
+    if ([inner isKindOfClass:[RNSScreenView class]]) {
+      child = inner;
+    }
+  }
+  if (![child isKindOfClass:[RNSScreenView class]]) {
+    RCTLogWarn(
+        @"[RNScreens] ScreenContainer insertReactSubview: expected RNSScreenView, got %@ (skipping; RNSScreenManager/RNSModalScreenManager -view must return RNSScreenView/RNSModalScreen under New Arch)",
+        NSStringFromClass(child.class));
+    return;
+  }
+  RNSScreenView *screenChild = (RNSScreenView *)child;
+  screenChild.reactSuperview = self;
+  [_reactSubviews insertObject:screenChild atIndex:atIndex];
+  react::LayoutMetrics screenLayoutMetrics = screenChild.newLayoutMetrics;
+  screenLayoutMetrics.frame = RCTRectFromCGRect(CGRectMake(0, 0, self.bounds.size.width, self.bounds.size.height));
+  [screenChild updateLayoutMetrics:screenLayoutMetrics oldLayoutMetrics:screenChild.oldLayoutMetrics];
+#else
   subview.reactSuperview = self;
   [_reactSubviews insertObject:subview atIndex:atIndex];
   [subview reactSetFrame:CGRectMake(0, 0, self.bounds.size.width, self.bounds.size.height)];
+#endif
 }
 
 - (void)removeReactSubview:(RNSScreenView *)subview
 {
+#if RCT_NEW_ARCH_ENABLED
+  UIView *child = subview;
+  if ([child isKindOfClass:[RCTLegacyViewManagerInteropComponentView class]]) {
+    RCTLegacyViewManagerInteropComponentView *interop = (RCTLegacyViewManagerInteropComponentView *)child;
+    UIView *inner = interop.contentView ?: interop.paperView;
+    if ([inner isKindOfClass:[RNSScreenView class]]) {
+      child = inner;
+    }
+  }
+  if (![child isKindOfClass:[RNSScreenView class]]) {
+    return;
+  }
+  RNSScreenView *screenChild = (RNSScreenView *)child;
+  screenChild.reactSuperview = nil;
+  [_reactSubviews removeObject:screenChild];
+#else
   subview.reactSuperview = nil;
   [_reactSubviews removeObject:subview];
+#endif
 }
 
 - (NSArray<UIView *> *)reactSubviews
